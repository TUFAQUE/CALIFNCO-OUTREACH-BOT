        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"model\": \"llama-3.1-8b-instant\",\n  \"max_tokens\": 150,\n  \"temperature\": 0.85,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an outreach specialist for Califnco, an AI automation agency. Write short, genuine, personalized Instagram DMs. Max 3 sentences. No emojis. Sound human. Reference their bio and connect to AI automation services.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a personalized DM to a business owner in digital marketing and AI space. Connect their work to how Califnco AI automation agency can help them save time and grow faster. Max 3 sentences, no emojis, sound human.\"\n    }\n  ]\n}",
        "options": {}
      },
