    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst scored = [];\n\nfor (const item of items) {\n  const data = item.json;\n  let score = 0;\n\n  const username = data.ownerUsername || data.username || '';\n  const followers = data.ownerFollowersCount || data.followersCount || 0;\n  const bio = (data.ownerBiography || data.biography || data.caption || '').toLowerCase();\n  const likes = data.likesCount || data.likes || 0;\n\n  if (followers >= 1000 && followers <= 50000) score += 30;\n  else if (followers > 50000 && followers <= 200000) score += 15;\n  else score += 5;\n\n  const engRate = followers > 0 ? (likes / followers) * 100 : 0;\n  if (engRate >= 3) score += 30;\n  else if (engRate >= 1) score += 15;\n  else score += 5;\n\n  const keywords = ['business', 'agency', 'marketing', 'startup', 'founder', 'ceo', 'growth', 'saas', 'ecommerce', 'coach', 'consultant', 'entrepreneur', 'digital', 'brand'];\n  for (const kw of keywords) {\n    if (bio.includes(kw)) score += 5;\n  }\n\n  if (score >= 20 && username) {\n    scored.push({\n      json: {\n        username: username,\n        full_name: data.ownerFullName || data.fullName || '',\n        followers: followers,\n        engagement_rate: engRate.toFixed(2),\n        bio: bio,\n        profile_url: `https://instagram.com/${username}`,\n        platform: 'instagram',\n        score: score,\n        status: 'new',\n        replied: false,\n        dm_sent_at: '',\n        followup_sent: false,\n        followup_sent_at: '',\n        timestamp: new Date().toISOString()\n      }\n    });\n  }\n}\n\nreturn scored.length > 0 ? scored : [{ json: { error: 'no qualified leads', total_checked: items.length } }];"
      },
