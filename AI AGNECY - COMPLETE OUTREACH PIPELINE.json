        "jsonBody": "{\n  \"model\": \"llama-3.1-8b-instant\",\n  \"max_tokens\": 120,\n  \"temperature\": 0.9,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You write follow-up DMs for Califnco AI agency. 2 sentences max. No emojis. Sound human. Mention a specific result like 70% less manual work or doubled lead flow.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a follow-up DM for a business owner. First message was 3 days ago, no reply. Mention a specific result Califnco delivered for a similar business. 2 sentences, no emojis.\"\n    }\n  ]\n}",
