      "id": "0a71bdd2-8aee-4032-9cbd-f98b3a95a1b7",
      "name": "Read All DM Data for Report",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.3,
      "position": [
        1776,
        368
      ]
    },
    {
      "parameters": {
        "jsCode": "const allData = $input.all().map(i => i.json);\nconst today = new Date();\nconst todayStr = today.toDateString();\n\nconst todayData = allData.filter(row => {\n  if (!row.dm_sent_at) return false;\n  return new Date(row.dm_sent_at).toDateString() === todayStr;\n});\n\nconst firstDMs = todayData.filter(r => r.status === 'dm_sent').length;\nconst followups = todayData.filter(r => r.status === 'followup_sent').length;\nconst totalDMs = firstDMs + followups;\nconst replies = allData.filter(r => r.replied === 'true' || r.replied === true).length;\nconst totalSent = allData.length;\nconst convRate = totalSent > 0 ? ((replies / totalSent) * 100).toFixed(1) : '0.0';\n\nconst topLeads = todayData\n  .sort((a, b) => (Number(b.score) || 0) - (Number(a.score) || 0))\n  .slice(0, 5)\n  .map(r => `@${r.username} (score: ${r.score}, followers: ${r.followers})`)\n  .join('\\n');\n\nconst reportDate = today.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });\n\nconst emailBody = `📊 DAILY OUTREACH REPORT — ${reportDate}\\n\\n━━━━━━━━━━━━━━━━━━━━━━━\\n✅ First DMs Sent Today:     ${firstDMs}\\n🔁 Follow-ups Sent Today:    ${followups}\\n📨 Total Sent Today:         ${totalDMs}\\n💬 Total Replies (all time): ${replies}\\n📈 Overall Conversion Rate:  ${convRate}%\\n━━━━━━━━━━━━━━━━━━━━━━━\\n\\n🏆 TOP LEADS TODAY:\\n${topLeads || 'No new leads today'}\\n\\n━━━━━━━━━━━━━━━━━━━━━━━\\n⚡ Powered by Califnco AI Outreach Bot`;\n\nreturn [{\n  json: {\n    report_date: reportDate,\n    dms_sent_today: firstDMs,\n    followups_sent_today: followups,\n    total_sent_today: totalDMs,\n    total_replies_alltime: replies,\n    overall_conversion_rate: convRate + '%',\n    top_leads_today: topLeads,\n    email_body: emailBody\n  }\n}];"
      },
