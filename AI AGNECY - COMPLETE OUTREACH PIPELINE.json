    {
      "parameters": {
        "jsCode": "const leads = $input.all();\nconst now = new Date();\nconst THREE_DAYS_MS = 3 * 24 * 60 * 60 * 1000;\n\nconst needsFollowup = leads.filter(item => {\n  const row = item.json;\n  if (row.status !== 'dm_sent') return false;\n  if (row.replied === 'true' || row.replied === true) return false;\n  if (row.followup_sent === 'true' || row.followup_sent === true) return false;\n  if (!row.dm_sent_at || row.dm_sent_at.trim() === '') return false;\n  const sentDate = new Date(row.dm_sent_at);\n  return (now - sentDate) >= THREE_DAYS_MS;\n});\n\nreturn needsFollowup.slice(0, 50).map(item => ({ json: item.json }));"
      },
